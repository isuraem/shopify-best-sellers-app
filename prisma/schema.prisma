// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

model CustomOrder {
  id         String   @id @default(cuid())

  // Order type: "Custom Pendant" | "Custom Set" | "Custom Grillz" | "Custom Rings"
  type       String

  // Customer details
  name       String
  email      String
  phone      String?
  country    String?
  instagram  String?
  comments   String?
  fileUrl    String?
  sourcePage String?
  sourceUrl  String?

  // Pendant fields
  pendantType   String?
  pendantSize   String?
  pendantColor  String?

  // Chain fields (used by Custom Set)
  chainLinkType  String?
  chainThickness String?
  chainLength    String?
  chainColor     String?

  // Grillz fields
  grillzTeeth String?
  grillzColor String?

  // Ring fields
  ringSize  String?
  ringColor String?

  submittedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([type])
  @@index([createdAt])
}
